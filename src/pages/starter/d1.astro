---
import { env } from 'cloudflare:workers';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadD1Demo } from '../../lib/d1-demo';

const cloudflareEnv = env as typeof env & { DB?: D1Database };
const payload = await loadD1Demo(cloudflareEnv.DB);
---

<BaseLayout
  title="D1 Starter App | Astro Supernova"
  description="A tiny guestbook-style D1 example included in the Astro Supernova starter."
>
  <main class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-700">Starter app</p>
      <h1 class="mt-4 text-4xl font-black tracking-tight text-slate-950 sm:text-5xl">
        Tiny D1 guestbook
      </h1>
      <p class="mt-4 text-lg leading-8 text-slate-700">
        This page turns the boilerplate into a small app example. Once D1 is configured, new
        messages can be posted through the included API route.
      </p>
    </div>

    <div class="mt-12 grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
      <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)]">
        <div class="flex items-center justify-between gap-4">
          <div>
            <h2 class="text-xl font-semibold text-slate-950">Starter messages</h2>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              Seeded by the D1 migration in `db/migrations`.
            </p>
          </div>
          <span class:list={[
            'rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em]',
            payload.status === 'ready'
              ? 'bg-emerald-100 text-emerald-800'
              : 'bg-amber-100 text-amber-800',
          ]}>
            {payload.status === 'ready' ? 'Ready' : 'Setup required'}
          </span>
        </div>

        <div class="mt-6 space-y-4">
          {
            payload.entries.length > 0 ? (
              payload.entries.map((entry) => (
                <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                  <div class="flex items-center justify-between gap-4">
                    <p class="font-semibold text-slate-950">{entry.author}</p>
                    <time class="text-xs uppercase tracking-[0.2em] text-slate-500">
                      {entry.created_at}
                    </time>
                  </div>
                  <p class="mt-3 text-sm leading-6 text-slate-700">{entry.message}</p>
                </article>
              ))
            ) : (
              <div class="rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-5 text-sm leading-6 text-slate-600">
                No starter rows are available yet. Apply the D1 migration to seed this list.
              </div>
            )
          }
        </div>
      </section>

      <aside class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-slate-100 shadow-[0_24px_80px_rgba(15,23,42,0.24)]">
        <h2 class="text-xl font-semibold text-white">Post a message</h2>
        <p class="mt-2 text-sm leading-6 text-slate-300">
          The form posts to `/api/d1-demo.json`. Without D1, it returns setup guidance instead of
          crashing.
        </p>

        <form
          id="d1-demo-form"
          action="/api/d1-demo.json"
          method="post"
          class="mt-6 space-y-4"
          data-ready={payload.status === 'ready'}
        >
          <label class="block text-sm">
            <span class="mb-2 block font-medium text-slate-200">Author</span>
            <input
              class="w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none ring-0 placeholder:text-slate-500"
              type="text"
              name="author"
              maxlength="40"
              placeholder="Astro fan"
            />
          </label>

          <label class="block text-sm">
            <span class="mb-2 block font-medium text-slate-200">Message</span>
            <textarea
              class="min-h-28 w-full rounded-2xl border border-white/10 bg-white/5 px-4 py-3 text-white outline-none ring-0 placeholder:text-slate-500"
              name="message"
              maxlength="280"
              placeholder="This starter feels publishable."
            ></textarea>
          </label>

          <button
            class="w-full rounded-full bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
            type="submit"
          >
            Send to D1
          </button>
        </form>

        <p id="d1-demo-status" class="mt-4 text-sm leading-6 text-slate-300">
          {payload.status === 'ready'
            ? 'D1 is connected. Submit the form to append a row and refresh the list.'
            : 'D1 is not configured yet. The response will show the exact remaining setup steps.'}
        </p>

        {
          payload.setupSteps && (
            <ol class="mt-5 space-y-2 text-sm leading-6 text-slate-400">
              {payload.setupSteps.map((step, index) => <li>{index + 1}. {step}</li>)}
            </ol>
          )
        }
      </aside>
    </div>
  </main>

  <script is:inline>
    const form = document.getElementById('d1-demo-form');
    const status = document.getElementById('d1-demo-status');

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      status.textContent = 'Submitting...';

      const response = await fetch('/api/d1-demo.json', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json();

      if (data.saved) {
        status.textContent = 'Saved. Reloading the page to show the latest rows.';
        window.location.reload();
        return;
      }

      status.textContent = data.error ?? 'D1 still needs setup.';
    });
  </script>
</BaseLayout>
