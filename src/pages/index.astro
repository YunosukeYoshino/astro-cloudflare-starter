---
import BaseLayout from '../layouts/BaseLayout.astro';

const featureCards = [
  {
    title: 'Cloudflare-ready',
    body: 'Astro adapter, Wrangler, generated worker types, and observability are already wired in.',
  },
  {
    title: 'D1 starter included',
    body: 'A migration and demo endpoint are bundled so Cloudflare database usage is visible on day one.',
  },
  {
    title: 'DX without drift',
    body: 'Biome, Husky, lint-staged, Vitest, and Playwright keep the template honest as it grows.',
  },
];

const commands = ['bun install', 'bun run dev', 'bun run typecheck', 'bun run test:e2e'];
---

<BaseLayout
  title="Astro Supernova | Astro boilerplate for Cloudflare"
  description="A focused Astro boilerplate for Cloudflare Workers with Tailwind CSS v4, Biome, Vitest, Playwright, and MDX."
>
  <main class="relative overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,_rgba(34,211,238,0.18),_transparent_45%),radial-gradient(circle_at_80%_20%,_rgba(251,191,36,0.16),_transparent_30%),linear-gradient(180deg,_#f8fafc_0%,_#e2e8f0_100%)]"></div>
    <section class="mx-auto flex min-h-[calc(100vh-5rem)] max-w-6xl flex-col justify-center px-4 py-20 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="inline-flex rounded-full border border-cyan-500/30 bg-white/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-700 shadow-sm backdrop-blur">
          Astro x Cloudflare Boilerplate
        </p>
        <h1 class="mt-6 max-w-4xl text-5xl font-black tracking-tight text-slate-950 sm:text-6xl lg:text-7xl">
          Astro boilerplate for Cloudflare that feels ready on day one.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-700">
          Ship a fast site or app surface with Astro 6, Tailwind CSS v4, Biome, Vitest,
          Playwright, MDX, and a Cloudflare deployment path that already exists.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/docs/getting-started"
          class="rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800"
        >
          Read the guide
        </a>
        <a
          href="/api/health.json"
          class="rounded-full border border-slate-300 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-white"
        >
          View edge endpoint
        </a>
        <a
          href="/docs/d1"
          class="rounded-full border border-cyan-300 bg-cyan-50/80 px-5 py-3 text-sm font-semibold text-cyan-950 transition hover:border-cyan-400 hover:bg-cyan-100"
        >
          See D1 guide
        </a>
        <a
          href="/starter/d1"
          class="rounded-full border border-slate-300 bg-white/80 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400 hover:bg-white"
        >
          Open starter app
        </a>
      </div>

      <div class="mt-14 grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
        <div class="grid gap-4 md:grid-cols-3 lg:grid-cols-3">
          {
            featureCards.map((card) => (
              <article class="rounded-3xl border border-white/70 bg-white/80 p-6 shadow-[0_24px_80px_rgba(15,23,42,0.08)] backdrop-blur">
                <h2 class="text-lg font-semibold text-slate-950">{card.title}</h2>
                <p class="mt-3 text-sm leading-6 text-slate-600">{card.body}</p>
              </article>
            ))
          }
        </div>

        <aside class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-slate-100 shadow-[0_24px_80px_rgba(15,23,42,0.24)]">
          <div class="flex items-center justify-between">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300">
              Quick start
            </p>
            <span class="rounded-full bg-cyan-400/15 px-3 py-1 text-xs font-medium text-cyan-200">
              Bun-first
            </span>
          </div>
          <ol class="mt-5 space-y-3 text-sm text-slate-300">
            {
              commands.map((command, index) => (
                <li class="flex items-start gap-3">
                  <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white">
                    {index + 1}
                  </span>
                  <code class="rounded-lg bg-white/5 px-3 py-2 text-cyan-200">{command}</code>
                </li>
              ))
            }
          </ol>
          <p class="mt-5 text-sm leading-6 text-slate-400">
            Includes sample JSON endpoints, MDX guide pages, a D1 migration, generated Cloudflare
            types, and CI-ready scripts.
          </p>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
