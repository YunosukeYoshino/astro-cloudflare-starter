---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A modern Astro boilerplate' } = Astro.props;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-slate-900 antialiased selection:bg-cyan-300 selection:text-cyan-900 dark:bg-slate-950 dark:text-slate-50">
    <slot />
  </body>
</html>
